# Ejemplo de archivo .env para Shiny Emissions v3
# Copia este contenido a un archivo llamado .env (sin .example)
# y reemplaza los valores con tus propias claves

# Google Gemini API Key
# Obtén tu clave en: https://console.cloud.google.com/apis
GEMINI_API_KEY=tu_clave_api_aqui

# Nota: NUNCA commits el archivo .env a Git
# El archivo .env está en .gitignore para proteger tus secrets
