library(dplyr)
library(ggplot2)
library(tidyr)
library(purrr)
dataDir  <- "./out_c01/"
dataFile <- "main_data.csv"
ingrFile <- "ingredients_Used.csv"
dietFile <- "ingredients_Used_xDiet.csv"
paretoFile <- "Pareto_data.csv"
lysName  <- "LYS_DIA"
options(ggplot2.discrete.fill = RColorBrewer::brewer.pal(12, "Paired"))
df.params = read.csv(paste0(dataDir,dataFile), na.strings = "inf")
df.pareto <- read.csv(paste0(dataDir,paretoFile), header = T, sep=';')
ggplot(df.pareto, aes(x=totalEmissions, y=totalCost)) +
geom_point(color = "orchid3", size = 3) +
geom_line(color = "orchid3", size = 1) +
labs(x= expression("Emissions (kg CO"[2]*"eq)"), y = "Cost (Euros)",
title = "Pareto frontier",
subtitle = "Total production planned") +
theme_light()
