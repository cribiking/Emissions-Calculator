library(dplyr)
library(ggplot2)
library(tidyr)
library(purrr)
dataDir  <- "./out_c01/"
dataFile <- "main_data.csv"
ingrFile <- "ingredients_Used.csv"
dietFile <- "ingredients_Used_xDiet.csv"
paretoFile <- "Pareto_data.csv"
lysName  <- "LYS_DIA"
options(ggplot2.discrete.fill = RColorBrewer::brewer.pal(12, "Paired"))
df.params = read.csv(paste0(dataDir,dataFile), na.strings = "inf")
# --- Plot 1: Scatter plot with random data ---
set.seed(123) # for reproducibility
set.seed(123) # for reproducibility
data_scatter <- tibble(
x = rnorm(100, mean = 10, sd = 2),
y = rnorm(100, mean = 50, sd = 10),
group = sample(c("A", "B", "C"), 100, replace = TRUE)
)
# random_plots.R
library(ggplot2)
library(dplyr) # For data manipulation if needed
# --- Plot 1: Scatter plot with random data ---
set.seed(123) # for reproducibility
data_scatter <- tibble(
x = rnorm(100, mean = 10, sd = 2),
y = rnorm(100, mean = 50, sd = 10),
group = sample(c("A", "B", "C"), 100, replace = TRUE)
)
random_scatter_plot <- ggplot(data_scatter, aes(x = x, y = y, color = group)) +
geom_point(alpha = 0.7) +
labs(title = "Random Scatter Plot",
x = "Variable X (Random Normal)",
y = "Variable Y (Random Normal)") +
theme_minimal()
# --- Plot 2: Histogram with random data ---
data_hist <- tibble(
value = rchisq(200, df = 3) # Random Chi-squared data
)
random_histogram_plot <- ggplot(data_hist, aes(x = value)) +
geom_histogram(binwidth = 0.5, fill = "skyblue", color = "black") +
labs(title = "Random Histogram",
x = "Value (Random Chi-squared)",
y = "Frequency") +
theme_minimal()
# --- Plot 3: Boxplot by group ---
data_boxplot <- tibble(
category = rep(LETTERS[1:4], each = 25),
values = c(rnorm(25, 10, 2), rnorm(25, 12, 3), rnorm(25, 8, 1), rnorm(25, 15, 4))
)
random_boxplot <- ggplot(data_boxplot, aes(x = category, y = values, fill = category)) +
geom_boxplot() +
labs(title = "Random Boxplot by Category",
x = "Category",
y = "Values") +
theme_minimal()
# You can add more plots here if you like!
library(ggplot2)
library(dplyr)
set.seed(42) # Usamos una semilla diferente para la reproducibilidad
# --- CHUNK 3: Gráfico de Caja (Boxplot) Aleatorio ---
# Define 'random_boxplot'
{
data_boxplot <- tibble(
category = rep(LETTERS[1:4], each = 25),
values = c(rnorm(25, 10, 2), rnorm(25, 12, 3), rnorm(25, 8, 1), rnorm(25, 15, 4))
)
random_boxplot <- ggplot(data_boxplot, aes(x = category, y = values, fill = category)) +
geom_boxplot(alpha = 0.7) +
labs(title = "3. Gráfico de Caja por Categoría",
x = "Categoría",
y = "Valores") +
scale_fill_brewer(palette = "Set3") +
theme_classic()
}
library(ggplot2)
library(dplyr)
set.seed(42) # Usamos una semilla diferente para la reproducibilidad
# --- CHUNK 1: Gráfico de Dispersión Aleatorio ---
# Define 'random_scatter_plot'
{
data_scatter <- tibble(
x = rnorm(100, mean = 10, sd = 2),
y = rnorm(100, mean = 50, sd = 10),
group = sample(c("A", "B", "C"), 100, replace = TRUE)
)
random_scatter_plot <- ggplot(data_scatter, aes(x = x, y = y, color = group)) +
geom_point(alpha = 0.7, size = 3) +
labs(title = "1. Gráfico de Dispersión Aleatorio",
x = "Variable X",
y = "Variable Y") +
theme_minimal()
}
# PASO CLAVE: Carga el script. Ahora todas las variables (los gráficos)
# 'random_scatter_plot', 'random_histogram_plot', 'random_boxplot'
# están disponibles en este entorno.
source("random_plots.R")
